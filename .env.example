# Required: comma-separated API keys for authentication
API_KEYS=your-generated-key-here

# Optional: bind host and port (defaults: 127.0.0.1 and 8000)
# BIND_HOST=127.0.0.1
# PORT=8000

# LLM provider API keys — only needed for the respective provider
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_CLOUD_API_KEY=
# MISTRAL_API_KEY=
# GOOGLE_AI_API_KEY=

# GitHub personal access token — allows for 5000 requests per hour (optional)
# Limit token capabilities to "public_repo" scope for security
# GITHUB_TOKEN=

# Tailscale (optional — used by docker-compose-tailscale*.yaml and make deploy)
# USETAILSCALE=false
# TAILSCALE_AUTH_KEY=tskey-...
# TAILSCALE_HOSTNAME=your-hostname

# MCP server — optional, for Claude.ai MCP Connector
# USEMCP=false          # set true to include MCP server (combines with USETAILSCALE)
# MCP_BEARER_TOKEN=
# MCP_PORT=8002
# MCP_ALLOWED_HOSTS=    # your Tailscale hostname, e.g. brainz.example.ts.net

# Deploy target (used by: make deploy / make sync)
# DEPLOY_HOST=your-server
# DEPLOY_PATH=/path/to/bRAInZ
